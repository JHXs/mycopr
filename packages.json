{
  "packages": [
    {
      "name": "cc-switch-cli",
      "enabled": true,
      "subdir": "cc-switch-cli",
      "spec": "cc-switch-cli.spec",
      "build_repos": ["ikunji/mycopr", "ikunji/cc-switch-cli"],
      "source_type": "github_release",
      "github_repo": "SaladDay/cc-switch-cli",
      "tag_prefix": "v",
      "update_strategy": "package_version"
    },
    {
      "name": "proxybridge",
      "enabled": true,
      "subdir": "proxybridge",
      "spec": "proxybridge.spec",
      "build_repos": ["ikunji/mycopr", "ikunji/proxybridge"],
      "source_type": "github_release",
      "github_repo": "InterceptSuite/ProxyBridge",
      "tag_prefix": "v",
      "update_strategy": "package_version"
    },
    {
      "name": "reframe",
      "enabled": true,
      "subdir": "reframe",
      "spec": "reframe.spec",
      "build_repos": ["ikunji/mycopr", "ikunji/reframe"],
      "source_type": "github_release",
      "github_repo": "AlynxZhou/reframe",
      "tag_prefix": "v",
      "update_strategy": "package_version"
    },
    {
      "name": "maple-mono-nf-cn-unhinted",
      "enabled": true,
      "subdir": "nerd-fonts",
      "spec": "maple-mono-nf-cn-unhinted.spec",
      "build_repos": ["ikunji/mycopr", "ikunji/nerd-fonts"],
      "source_type": "github_release",
      "github_repo": "subframe7536/maple-font",
      "tag_prefix": "v",
      "update_strategy": "package_version"
    },
    {
      "name": "zotero",
      "enabled": true,
      "subdir": "zotero",
      "spec": "zotero.spec",
      "build_repos": ["ikunji/mycopr"],
      "source_type": "aur_pkgbuild",
      "aur_package": "zotero-bin",
      "update_strategy": "package_version"
    },
    {
      "name": "um-cli",
      "enabled": true,
      "subdir": "um-cli-copr",
      "spec": "um-cli.spec",
      "build_repos": ["ikunji/mycopr", "ikunji/um-cli"],
      "source_type": "gitea_release",
      "gitea_base_url": "https://git.um-react.app",
      "gitea_repo": "um/cli",
      "tag_prefix": "v",
      "update_strategy": "package_version"
    },
    {
      "name": "cto2api",
      "enabled": true,
      "subdir": "cto2api",
      "spec": "cto2api.spec",
      "build_repos": ["ikunji/mycopr", "ikunji/cto2api"],
      "source_type": "git_commit",
      "github_repo": "wyeeeee/cto2api",
      "github_branch": "main",
      "update_strategy": "commit"
    }
  ]
}
